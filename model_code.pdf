1 0 0 1 48 90 Tm (    top_tangent_scale = KEYHOLE_TOP_RADIUS / \(KEYHOLE_TOP_RADIUS + KEYHOLE_BLEND_RADIUS\)) Tj
1 0 0 1 48 78 Tm (    top_tangent_x = fillet_center_x * top_tangent_scale) Tj
1 0 0 1 48 66 Tm (    top_tangent_angle = degrees\(acos\(top_tangent_x / KEYHOLE_TOP_RADIUS\)\)) Tj
