1 0 0 1 48 186 Tm (def _keyhole_profile\(\):) Tj
1 0 0 1 48 174 Tm (    """Build a single keyhole profile centered on the top circular head.""") Tj
1 0 0 1 48 162 Tm (    neck_half_width = KEYHOLE_NECK_WIDTH / 2) Tj
1 0 0 1 48 150 Tm (    fillet_center_x = neck_half_width + KEYHOLE_BLEND_RADIUS) Tj
1 0 0 1 48 138 Tm (    fillet_center_y = -sqrt\() Tj
1 0 0 1 48 126 Tm (        \(KEYHOLE_TOP_RADIUS + KEYHOLE_BLEND_RADIUS\) ** 2 - fillet_center_x**2) Tj
1 0 0 1 48 114 Tm (    \)) Tj
